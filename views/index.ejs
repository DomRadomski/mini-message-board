<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Messages</title>
</head>
<body>

<%- include('header') %>
<h1>Messages</h1>

    <ul>
    <% messages.forEach(function(message) { %>
        <li>
        <strong><%= message.user %></strong>: <%= message.text %>
        <br>
        <small><%= message.added.toLocaleString() %></small>
        <br>
        <a href="/message/<%= message.id %>"><button type="button">Open</button></a>
        </li>
    <% }); %>
    </ul>
</body>
</html>